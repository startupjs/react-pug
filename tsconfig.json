{
  "compilerOptions": {
    "strict": true,
    "target": "ES2020",
    "module": "commonjs",
    "moduleResolution": "node",
    "baseUrl": ".",
    "paths": {
      "@startupjs/react-pug-core": [
        "packages/react-pug-core/src/index.ts"
      ]
    },
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "sourceMap": true
  },
  "include": ["packages/*/src/**/*.ts"],
  "exclude": ["node_modules", "dist", "out", "packages/**/dist"]
}
