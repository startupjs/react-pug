{
  "compilerOptions": {
    "strict": true,
    "target": "ES2020",
    "module": "commonjs",
    "moduleResolution": "node",
    "jsx": "react-jsx",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "out",
    "plugins": [
      { "name": "@react-pug/typescript-plugin-react-pug" }
    ]
  },
  "include": ["*.tsx", "*.ts"]
}
