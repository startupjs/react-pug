{
  "name": "vscode-react-pug-tsx",
  "displayName": "Pug React IntelliSense",
  "description": "JSX-grade IntelliSense for pug`` tagged template literals in React projects",
  "version": "0.0.1",
  "publisher": "startupjs",
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:typescript",
    "onLanguage:typescriptreact",
    "onLanguage:javascript",
    "onLanguage:javascriptreact"
  ],
  "main": "./dist/client.js",
  "contributes": {
    "typescriptServerPlugins": [
      {
        "name": "@startupjs/typescript-plugin-react-pug",
        "enableForWorkspaceTypeScriptVersions": true
      }
    ],
    "configuration": {
      "title": "Pug React IntelliSense",
      "properties": {
        "pugReact.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable/disable the Pug React IntelliSense extension"
        },
        "pugReact.diagnostics.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable/disable pug-specific diagnostics (parse errors)"
        },
        "pugReact.tagFunction": {
          "type": "string",
          "default": "pug",
          "description": "The tag function name to recognize (for users who alias the import)"
        },
        "pugReact.injectCssxjsTypes": {
          "type": "string",
          "default": "auto",
          "enum": [
            "none",
            "auto",
            "force"
          ],
          "enumDescriptions": [
            "Never inject cssxjs React attribute types.",
            "Inject cssxjs React attribute types only when startupjs or cssxjs is present in dependencies/peerDependencies.",
            "Always inject cssxjs React attribute types for files with pug templates."
          ],
          "description": "Controls automatic injection of cssxjs React attribute types (part/styleName)."
        }
      }
    },
    "configurationDefaults": {
      "emmet.excludeLanguages": [
        "markdown",
        "pug"
      ],
      "emmet.showExpandedAbbreviation": "inMarkupAndStylesheetFilesOnly"
    },
    "commands": [
      {
        "command": "pugReact.showShadowTsx",
        "title": "Pug React: Show Shadow TSX"
      }
    ],
    "grammars": [
      {
        "scopeName": "inline.pug-template-literal",
        "path": "./syntaxes/pug-template-literal.json",
        "injectTo": [
          "source.ts",
          "source.tsx",
          "source.js",
          "source.jsx"
        ],
        "embeddedLanguages": {
          "source.pug": "jade",
          "text.pug": "jade"
        }
      }
    ]
  },
  "dependencies": {
    "@startupjs/typescript-plugin-react-pug": "^0.0.1"
  },
  "private": true
}
