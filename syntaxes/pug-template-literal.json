{
  "scopeName": "inline.pug-template-literal",
  "injectionSelector": "L:source.ts,L:source.tsx,L:source.js,L:source.jsx",
  "patterns": [
    {
      "include": "#pug-tagged-template"
    }
  ],
  "repository": {
    "pug-tagged-template": {
      "begin": "(?<=pug)\\s*(`)",
      "beginCaptures": {
        "1": {
          "name": "punctuation.definition.string.template.begin.ts"
        }
      },
      "end": "(`)",
      "endCaptures": {
        "1": {
          "name": "punctuation.definition.string.template.end.ts"
        }
      },
      "contentName": "source.pug",
      "patterns": [
        {
          "include": "source.pug"
        }
      ]
    }
  }
}
